<Window x:Class="TADM_reader.filterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TADM_reader"
        mc:Ignorable="d"
        Title="TADM Analyzer" Height="218" Width="238">
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="135" FontSize="18" FontWeight="Bold"><Run Language="fr-ch" Text="Filter"/></TextBlock>
        <Image Height="27" Margin="0,0,7,0" VerticalAlignment="Top" Source="/KBI_logo.png" HorizontalAlignment="Right" Width="78"/>
        <Image Height="29" Margin="0,0,89,0" VerticalAlignment="Top" Source="/KBI_CellCultivationIcon.png" HorizontalAlignment="Right" Width="30"/>
        <TextBox x:Name ="volumeMinTextBox" HorizontalAlignment="Left" Margin="10,39,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Width="62" Height="20" TextChanged="textBoxVolumeMin_TextChanged"/>
        <TextBlock HorizontalAlignment="Left" Margin="81,39,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="20" Width="68"><Run Text=" "/><Run Language="fr-ch" Text="&lt; "/><Run Text="Volume"/><Run Language="fr-ch" Text=" &gt;"/></TextBlock>
        <TextBox x:Name ="volumeMaxTextBox" HorizontalAlignment="Left" Margin="158,39,0,0" TextWrapping="Wrap" Text="5000" VerticalAlignment="Top" Width="62" Height="20" TextChanged="textBoxVolumeMax_TextChanged"/>
        <CheckBox x:Name="Chan1_1mL_CheckBox" Content="Channel 1" HorizontalAlignment="Left" Margin="10,90,0,0" VerticalAlignment="Top" IsChecked="True" Checked="Chan1_1mL_Changed" Unchecked="Chan1_1mL_Changed"/>
        <CheckBox x:Name="Chan2_1mL_CheckBox" Content="Channel 2" HorizontalAlignment="Left" Margin="10,110,0,0" VerticalAlignment="Top" IsChecked="True" Checked="Chan2_1mL_Changed" Unchecked="Chan2_1mL_Changed"/>
        <CheckBox x:Name="Chan3_1mL_CheckBox" Content="Channel 3" HorizontalAlignment="Left" Margin="10,130,0,0" VerticalAlignment="Top" IsChecked="True" Checked="Chan3_1mL_Changed" Unchecked="Chan3_1mL_Changed"/>
        <CheckBox x:Name="Chan4_1mL_CheckBox" Content="Channel 4" HorizontalAlignment="Left" Margin="10,150,0,0" VerticalAlignment="Top" IsChecked="True" Checked="Chan4_1mL_Changed" Unchecked="Chan4_1mL_Changed"/>
        <CheckBox x:Name="Chan1_5mL_CheckBox" Content="Channel 1" HorizontalAlignment="Left" Margin="147,90,0,0" VerticalAlignment="Top" IsChecked="True" Checked="Chan1_5mL_Changed" Unchecked="Chan1_5mL_Changed"/>
        <CheckBox x:Name="Chan2_5mL_CheckBox" Content="Channel 2" HorizontalAlignment="Left" Margin="147,110,0,0" VerticalAlignment="Top" IsChecked="True" Checked="Chan2_5mL_Changed" Unchecked="Chan2_5mL_Changed"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,69,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="20" Width="68"><Run Language="fr-ch" Text="1mL channel"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="147,69,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="20" Width="68"><Run Language="fr-ch" Text="5"/><Run Text="mL channel"/></TextBlock>

    </Grid>
</Window>
