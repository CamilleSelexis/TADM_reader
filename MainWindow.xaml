<Window x:Class="TADM_reader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TADM_reader"
        mc:Ignorable="d"
        Title="TADM Analyzer" Height="200" Width="450">
    <Grid>

        <Border BorderBrush="Black" BorderThickness="1" Margin="10,70,147,5"/>

        <Border BorderBrush="Black" BorderThickness="1" Height="25" Margin="10,41,10,0" VerticalAlignment="Top"/>
        <Button Content="Select file" HorizontalAlignment="Right" Margin="0,42,10,0" VerticalAlignment="Top" Height="23" Width="60" Click="Button_Click"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,24,0,0" TextWrapping="Wrap" Text="Please select a file" VerticalAlignment="Top" Height="17" Width="101"/>
        <Button Content="Run analysis" Margin="0,0,5,5" Click="Button_Click_1" HorizontalAlignment="Right" Width="104" Height="41" VerticalAlignment="Bottom"/>
        <CheckBox x:Name="CheckBoxCSV" Content="Export raw data as csv" Margin="0,0,10,51" Height="15" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="137"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="135" FontSize="18" FontWeight="Bold"><Run Text="TADM "/><Run Language="fr-ch" Text="A"/><Run Text="nalyzer"/></TextBlock>
        <TextBlock x:Name="TextBlockFile" Margin="10,45,70,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="17"/>
        <Image Height="27" Margin="0,0,7,0" VerticalAlignment="Top" Source="/KBI_logo.png" HorizontalAlignment="Right" Width="78"/>
        <Image Height="29" Margin="0,0,89,0" VerticalAlignment="Top" Source="/KBI_CellCultivationIcon.png" HorizontalAlignment="Right" Width="30"/>
        <ScrollViewer Margin="10,71,147,5">
            <TextBlock x:Name="TextBlock_log" Margin="0,0,0,0" TextWrapping="Wrap" Width="Auto" Height="Auto" Text=""/>
        </ScrollViewer>
        
        <Button Content="Filter Data" Margin="0,70,10,69" Click="Button_Click_2" HorizontalAlignment="Right" Width="93" Height="20"/>
        

    </Grid>
</Window>
